      "created_by_ref": "identity--5ebdfb4b-4841-58e5-9b0b-1a7b4fb922ad",
      "name": "CVE-2026-24061 Exploit Payload",
      "description": "Detects the Telnet NEW-ENVIRON sub-negotiation payload containing VAR USER VALUE \"-f root\" used to exploit CVE-2026-24061. Hex: FF FA 27 00 00 55 53 45 52 01 2D 66 20 72 6F 6F 74 FF F0",
      "indicator_types": [
        "malicious-activity"
      ],
      "pattern": "[network-traffic:dst_port = 23 AND network-traffic:extensions.'tcp-ext'.src_payload_ref.payload_bin = 'v/onAABVU0VSAS1mIHJvb3T/8A==']",
      "pattern_type": "stix",
